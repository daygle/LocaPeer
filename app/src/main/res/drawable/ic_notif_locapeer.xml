<?xml version="1.0" encoding="utf-8"?>
<!--
  LocaPeer notification small icon: the launcher's location-pin + peer-network
  motif rendered as a flat white silhouette (notification icons are tinted by
  the system, so only alpha/shape matters — colour is ignored).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Pin outline (teardrop) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M12,2.6 C7.3,2.6 3.6,6.3 3.6,11 C3.6,17.4 12,21.4 12,21.4 C12,21.4 20.4,17.4 20.4,11 C20.4,6.3 16.7,2.6 12,2.6 Z" />

    <!-- Peer-network links inside the pin -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.3"
        android:strokeLineCap="round"
        android:pathData="M12,11 L8.4,7.9 M12,11 L15.6,7.9" />

    <!-- Centre node -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,11 m-1.9,0 a1.9,1.9 0,1,1 3.8,0 a1.9,1.9 0,1,1 -3.8,0" />

    <!-- Left node -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M8.4,7.9 m-1.25,0 a1.25,1.25 0,1,1 2.5,0 a1.25,1.25 0,1,1 -2.5,0" />

    <!-- Right node -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M15.6,7.9 m-1.25,0 a1.25,1.25 0,1,1 2.5,0 a1.25,1.25 0,1,1 -2.5,0" />
</vector>
