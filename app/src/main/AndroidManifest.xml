<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Activity Recognition: sensor-based motion classification that corroborates the
         GPS-speed classifier (see MotionFusion). Runtime permission on Android 10+;
         a normal install-time permission via the GMS name on older releases. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission
        android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION"
        android:maxSdkVersion="28" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Wake lock to keep CPU running during background work -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Camera for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Receive boot completed to restart services -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".LocaPeerApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.LocaPeer"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.LocaPeer"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:label="LocaPeer Invite">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="locapeer" android:host="invite" />
            </intent-filter>
        </activity>

        <!-- Heartbeat foreground service -->
        <service
            android:name=".beacon.HeartbeatService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- WorkManager worker for missed heartbeat checks -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Boot receiver to restart heartbeat service -->
        <receiver
            android:name=".beacon.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Notification action receiver for mutual tracking requests -->
        <receiver
            android:name=".invite.TrackRequestReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.locapeer.TRACK_DECLINE" />
            </intent-filter>
        </receiver>

        <!-- Notification action receiver for supervised mode registration -->
        <receiver
            android:name=".supervised.SupervisedRegisterReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.locapeer.SUPERVISED_REGISTER_ACCEPT" />
                <action android:name="com.locapeer.SUPERVISED_REGISTER_DECLINE" />
            </intent-filter>
        </receiver>

        <!-- OSMDroid tile cache path (optional) -->
        <meta-data
            android:name="osmdroid.cachepath"
            android:value="osmdroid" />

        <!-- Persists the per-app language on API < 33 (AppCompat backport). On API 33+ the
             framework LocaleManager stores it and this service is ignored. -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

    </application>

</manifest>
